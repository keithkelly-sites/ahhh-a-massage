---
import Layout from '../layouts/Layout.astro';

const testimonials = [
  { title: "I Wouldn't Be Getting Married...", text: "If Margie hadn't helped me get my life back — I would have missed out on being a husband and a father. Recovery is a process. Whatever she does to the muscles makes the pain go away. I told her she is not allowed to retire unless she can replace herself with an equally skilled and compassionate person. My life is good.", featured: true },
  { title: "Ahhh Story of Incredible Healing", author: "Gail P.", text: "Margie and I would both do research between sessions and bring new ideas to the table. Each week was a new experience. It was a process, but together we worked as a TEAM to help me heal. AND I DID. It took some time, but the pain is finally gone. She definitely went above and beyond my expectations." },
  { author: "Barb", text: "I've been going to a massage therapist for over 20 years now. It has been a huge blessing for me to find Ahhh A Massage. Margie brings her knowledge and expertise to what she does but it's so much more than that. She really cares about the person that she's working with which I believe makes Margie unique." },
  { author: "Theresa P.", text: "Ahhh a Massage is a sanctuary for those who are filled with stress and worry. From the flower gardens and pretty statues in the yard, to the beautiful gold fish swimming in the pond near the porch, you feel you have entered another world. Margie greets you at the door with a smile. It is as close to Heaven as you can imagine." },
  { author: "Mark M.", text: "Margie Webb is a talented professional who emphasizes an effective and individualized holistic healing program tailored for each of her clients. She is an astute listener and works with clients to eliminate chronic pain and optimize recovery. The results have been outstanding." },
  { author: "Wendy S.", text: "She is very good and if you live in the area I encourage you to pamper yourself by checking it out! She worked wonders for me and her skills helped Sarah to compete with her school winter guard team in spite of an injury." },
  { author: "Carole Hesse S.", text: "I love my massages with Margie so much that I have a massage every month. I highly recommend her massages. She is very knowledgeable having been a nurse in the past." },
  { author: "Amy Blazewick A.", text: "Margie is a great massage therapist, and provides a relaxing environment for massages. She focuses on her client's needs and how she can lessen any pain in the body. Because of her nursing background, she has so much to offer." },
];
---

<Layout
  title="Testimonials | Ahhh A Massage — McMurray, PA"
  description="Read real stories from clients whose lives have been transformed by Margie Webb's therapeutic massage at Ahhh A Massage."
>
  <section class="bg-sage-pale py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="line-sage mb-4"></div>
        <h1 class="font-display text-4xl md:text-5xl font-light text-charcoal leading-tight mb-6">Testimonials</h1>
        <p class="text-earth text-lg">Real stories from people whose lives have changed.</p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- Featured -->
      <div class="bg-sage-dark rounded-3xl p-8 md:p-12 mb-12 reveal">
        <p class="text-sage-light uppercase tracking-[0.2em] text-xs font-semibold mb-4">Featured Story</p>
        <h2 class="font-display text-2xl md:text-3xl text-white font-light italic leading-relaxed mb-6">
          "{testimonials[0].title}"
        </h2>
        <p class="text-white/70 leading-relaxed">{testimonials[0].text}</p>
      </div>

      <!-- Rest -->
      <div class="space-y-6">
        {testimonials.slice(1).map(t => (
          <blockquote class="bg-white rounded-2xl p-8 border border-sage-pale reveal">
            <p class="text-earth leading-relaxed mb-4">{t.text}</p>
            {t.author && <cite class="not-italic text-sage-dark font-medium text-sm">— {t.author}</cite>}
          </blockquote>
        ))}
      </div>

      <div class="text-center mt-12 reveal">
        <a
          href="https://www.google.com/search?q=ahhh+a+massage#lrd=0x883455930fcce22d:0x9524b19615e62d7,3,,,"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-sage"
        >
          Leave Us a Review on Google
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" /></svg>
        </a>
      </div>
    </div>
  </section>
</Layout>
