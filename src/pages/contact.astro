---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Contact Ahhh A Massage | McMurray, PA"
  description="Contact Margie Webb at Ahhh A Massage. Call (412) 877-8569 or send a message. 310 East McMurray Rd, McMurray, PA 15317."
>
  <section class="bg-sage-pale py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="line-sage mb-4"></div>
        <h1 class="font-display text-4xl md:text-5xl font-light text-charcoal leading-tight mb-6">Contact</h1>
        <p class="text-earth text-lg">Schedule an appointment with a therapist you can trust.</p>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-16">
        <div class="lg:col-span-3 reveal">
          <h2 class="font-display text-2xl font-light text-charcoal mb-2">Send Margie a Message</h2>
          <p class="text-earth mb-8 text-sm">For appointments, questions, or gift certificate inquiries.</p>
          <p class="text-sm text-sage bg-sage-pale rounded-lg px-4 py-3 mb-6 form-notice">This form will be active once the site is live.</p>
          <form action="#" method="POST" class="space-y-5">
            <div class="grid sm:grid-cols-2 gap-5">
              <div>
                <label for="first-name" class="block text-sm font-medium text-charcoal mb-1.5">First Name <span class="text-lavender">*</span></label>
                <input type="text" id="first-name" name="firstName" required class="w-full px-4 py-3 rounded-xl border border-sage-pale bg-white text-charcoal placeholder-earth/40 focus:border-sage focus:ring-2 focus:ring-sage/20 transition-colors" placeholder="First name" />
              </div>
              <div>
                <label for="last-name" class="block text-sm font-medium text-charcoal mb-1.5">Last Name <span class="text-lavender">*</span></label>
                <input type="text" id="last-name" name="lastName" required class="w-full px-4 py-3 rounded-xl border border-sage-pale bg-white text-charcoal placeholder-earth/40 focus:border-sage focus:ring-2 focus:ring-sage/20 transition-colors" placeholder="Last name" />
              </div>
            </div>
            <div>
              <label for="email" class="block text-sm font-medium text-charcoal mb-1.5">Email <span class="text-lavender">*</span></label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-sage-pale bg-white text-charcoal placeholder-earth/40 focus:border-sage focus:ring-2 focus:ring-sage/20 transition-colors" placeholder="your@email.com" />
            </div>
            <div>
              <label for="phone" class="block text-sm font-medium text-charcoal mb-1.5">Phone</label>
              <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-sage-pale bg-white text-charcoal placeholder-earth/40 focus:border-sage focus:ring-2 focus:ring-sage/20 transition-colors" placeholder="(555) 555-5555" />
            </div>
            <div>
              <label for="message" class="block text-sm font-medium text-charcoal mb-1.5">Message <span class="text-lavender">*</span></label>
              <textarea id="message" name="message" required rows="5" class="w-full px-4 py-3 rounded-xl border border-sage-pale bg-white text-charcoal placeholder-earth/40 focus:border-sage focus:ring-2 focus:ring-sage/20 transition-colors resize-y" placeholder="Tell Margie about your needs..."></textarea>
            </div>
            <button type="submit" class="btn btn-sage">Send Message</button>
          </form>
        </div>

        <div class="lg:col-span-2 reveal">
          <div class="sticky top-28 space-y-6">
            <div class="bg-sage-dark rounded-2xl p-6 text-white">
              <h3 class="font-display text-lg text-white mb-4">Call Margie</h3>
              <a href="tel:4128778569" class="flex items-center gap-3 text-sage-light hover:text-white transition-colors font-semibold text-lg">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" /></svg>
                (412) 877-8569
              </a>
              <p class="text-white/50 text-xs mt-3">Free consultation available</p>
            </div>

            <div class="bg-white rounded-2xl p-6 border border-sage-pale">
              <h3 class="font-display text-lg font-medium text-charcoal mb-3">Location</h3>
              <address class="not-italic text-sm text-earth space-y-1">
                <p><a href="https://www.google.com/maps/place/310+E+McMurray+Rd,+Canonsburg,+PA+15317" target="_blank" rel="noopener noreferrer" class="hover:text-sage-dark transition-colors">310 East McMurray Rd<br />McMurray, PA 15317</a></p>
              </address>
            </div>

            <div class="bg-white rounded-2xl p-6 border border-sage-pale">
              <h3 class="font-display text-lg font-medium text-charcoal mb-3">Hours</h3>
              <div class="text-sm text-earth space-y-1">
                <p><strong class="text-charcoal">Mon – Thu:</strong> 9:00 AM – 8:00 PM</p>
                <p><strong class="text-charcoal">Friday:</strong> 9:00 AM – 5:00 PM</p>
                <p><strong class="text-charcoal">Saturday:</strong> By Appointment</p>
                <p class="text-earth/50">Sunday: Closed</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
