---
import Layout from '../layouts/Layout.astro';

/** @type application/ld+json — rendered via Layout */
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "HealthAndBeautyBusiness",
  "name": "Ahhh A Massage",
  "description": "Therapeutic massage in McMurray, PA. Margie Webb, R.N., BCTMB, offers holistic massage therapy with 25+ years of experience.",
  "url": "https://ahhhamassage.keithkelly.dev",
  "telephone": "(412) 877-8569",
  "address": { "@type": "PostalAddress", "streetAddress": "310 East McMurray Rd", "addressLocality": "McMurray", "addressRegion": "PA", "postalCode": "15317" },
  "openingHoursSpecification": [
    { "@type": "OpeningHoursSpecification", "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday"], "opens": "09:00", "closes": "20:00" },
    { "@type": "OpeningHoursSpecification", "dayOfWeek": "Friday", "opens": "09:00", "closes": "17:00" }
  ],
  "image": "https://ahhhamassage.keithkelly.dev/images/garden.jpg",
  "priceRange": "$$",
  "sameAs": ["https://www.facebook.com/margiebatewebb/"]
};

const services = [
  { name: 'Relaxation Massage', desc: 'Release tension, lower stress levels, improve circulation, and receive the therapeutic touch you\'re missing in your life.', icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" /></svg>' },
  { name: 'Medical Massage', desc: 'Manage pain, reduce inflammation, relieve nerve compression — for arthritis, fibromyalgia, carpal tunnel, and post-surgery recovery.', icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>' },
  { name: 'Table Massage', desc: 'A full-body nurturing experience for 60 or 90 minutes, working out all the kinks and stress of your day.', icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>' },
  { name: 'Chair Massage', desc: 'Short on time? A convenient treatment to squeeze into a lunch break. Return to work feeling more alert and focused.', icon: '<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>' },
];
---

<Layout
  title="Ahhh A Massage | Therapeutic Massage in McMurray, PA"
  description="Therapeutic massage in McMurray, PA by Margie Webb, R.N., BCTMB. 25+ years of experience. Holistic approach for pain relief, relaxation, and healing."
  jsonLd={jsonLd}
>
  <!-- Hero — serene garden -->
  <section class="relative min-h-[80vh] flex items-center overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/garden.jpg" alt="Serene garden at Ahhh A Massage" class="w-full h-full object-cover" loading="eager" />
      <div class="absolute inset-0 bg-gradient-to-r from-charcoal/70 via-charcoal/40 to-transparent"></div>
    </div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-24 w-full">
      <div class="max-w-lg">
        <div class="line-sage mb-6"></div>
        <h1 class="font-display text-4xl sm:text-5xl md:text-6xl font-light text-white leading-[1.15] mb-6">
          Escape from<br />the Ordinary to<br />the <em class="font-medium">Extraordinary</em>
        </h1>
        <p class="text-white/75 leading-relaxed mb-10 max-w-sm">
          Nurturing massage to relax and rejuvenate your mind, body, and spirit. 25+ years of experience.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="tel:4128778569" class="btn btn-sage">
            Call Margie
            <span class="text-white/70 font-normal">(412) 877-8569</span>
          </a>
          <a href="/services" class="btn btn-white">Our Services</a>
        </div>
      </div>
    </div>
  </section>

  <!-- Intro strip -->
  <section class="bg-sage-pale py-10">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <p class="font-display text-xl md:text-2xl text-sage-dark leading-relaxed italic">
        "I use a holistic approach for your therapeutic massage — as both a registered nurse and massage therapist, I want to get to the root of your problem."
      </p>
      <p class="text-earth text-sm mt-4 font-medium">— Margie Webb, R.N., BCTMB</p>
    </div>
  </section>

  <!-- Services -->
  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mb-14 reveal">
        <div class="line-sage mb-4"></div>
        <h2 class="font-display text-3xl md:text-4xl font-light text-charcoal">Holistic Therapeutic Massage</h2>
        <p class="text-earth mt-4 leading-relaxed">Every session is designed around you — your pain, your stress, your goals for healing.</p>
      </div>

      <div class="grid sm:grid-cols-2 gap-6 reveal">
        {services.map(s => (
          <a href="/services" class="group bg-white rounded-2xl p-8 border border-sage-pale hover:border-sage-light transition-all duration-300 hover:shadow-lg hover:shadow-sage/10 hover:-translate-y-1">
            <div class="w-10 h-10 rounded-full bg-sage-pale flex items-center justify-center text-sage" set:html={s.icon} />
            <h3 class="font-display text-xl font-medium text-charcoal mt-4 mb-3 group-hover:text-sage-dark transition-colors">{s.name}</h3>
            <p class="text-earth text-sm leading-relaxed">{s.desc}</p>
          </a>
        ))}
      </div>

      <div class="text-center mt-10">
        <a href="/services" class="btn btn-outline">Learn More About Our Services</a>
      </div>
    </div>
  </section>

  <!-- The Setting -->
  <section class="bg-stone py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-2 gap-12 lg:gap-20 items-center">
        <div class="reveal">
          <div class="line-sage mb-4"></div>
          <h2 class="font-display text-3xl md:text-4xl font-light text-charcoal mb-6">This House...</h2>
          <p class="text-earth leading-relaxed mb-6">
            ...was chosen for its unique design. The serenity gardens and fish pond are a part of the plan to relax and refresh you. The massage room engulfs you in low lights and calming music. You sink onto a heated table as you nestle in soft cozy flannel sheets. The music lets your mind drift away.
          </p>
          <a href="/about" class="btn btn-outline">Meet Margie</a>
        </div>
        <div class="reveal grid grid-cols-2 gap-3">
          <img src="/images/house-front.jpg" alt="Front of the massage studio in McMurray" class="rounded-2xl w-full aspect-[3/4] object-cover col-span-2" loading="lazy" />
          <img src="/images/patio.jpg" alt="Garden seating area" class="rounded-2xl w-full aspect-square object-cover" loading="lazy" />
          <img src="/images/garden-2.jpg" alt="Serenity garden" class="rounded-2xl w-full aspect-square object-cover" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Testimonial feature -->
  <section class="py-20 lg:py-28">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 text-center reveal">
      <div class="line-sage mx-auto mb-6"></div>
      <p class="text-sage uppercase tracking-[0.2em] text-xs font-semibold mb-6">Testimonial</p>
      <blockquote class="font-display text-2xl md:text-3xl lg:text-4xl font-light text-charcoal leading-relaxed italic">
        "If Margie hadn't helped me get my life back — I would have missed out on being a husband and a father. My life is good."
      </blockquote>
      <div class="mt-8">
        <a href="/testimonials" class="btn btn-outline">Read Our Testimonials</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="relative py-20 lg:py-28 overflow-hidden">
    <div class="absolute inset-0">
      <img src="/images/relaxation.jpg" alt="" class="w-full h-full object-cover" aria-hidden="true" loading="lazy" />
      <div class="absolute inset-0 bg-sage-dark/85"></div>
    </div>
    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-light text-white mb-6 reveal">
        Begin Your <em class="font-medium">Healing</em> Journey
      </h2>
      <p class="text-white/70 mb-4 reveal">Call for a free consultation.</p>
      <p class="text-white/60 text-sm mb-10 reveal">Mon–Thu 9am–8pm · Fri 9am–5pm · Sat by appointment</p>
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 reveal">
        <a href="tel:4128778569" class="btn bg-white text-sage-dark border-2 border-white hover:bg-transparent hover:text-white">
          Call Margie — (412) 877-8569
        </a>
        <a href="/contact" class="btn border-2 border-white/30 text-white hover:bg-white/10">Send a Message</a>
      </div>
    </div>
  </section>

  <!-- Credentials -->
  <section class="py-12 bg-sage-pale/50">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 flex flex-wrap items-center justify-center gap-8">
      <img src="/images/amta-logo.png" alt="American Massage Therapy Association Member" class="h-12 opacity-60" loading="lazy" />
      <img src="/images/bctmb-logo.png" alt="Board Certified in Therapeutic Massage and Bodywork" class="h-12 opacity-60" loading="lazy" />
      <p class="text-earth text-sm">Readers' Choice Award — Massage Therapy</p>
    </div>
  </section>
</Layout>
