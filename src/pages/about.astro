---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Meet Margie Webb, R.N., BCTMB | Ahhh A Massage"
  description="Margie Webb is a registered nurse and licensed massage therapist with 25+ years of experience. Board certified, Readers' Choice Award recipient."
>
  <section class="bg-sage-pale py-16 lg:py-24">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl">
        <div class="line-sage mb-4"></div>
        <h1 class="font-display text-4xl md:text-5xl font-light text-charcoal leading-tight mb-6">Meet Margie</h1>
        <p class="text-earth text-lg">Your massage therapist — a nurse, licensed massage therapist, author, and public speaker.</p>
      </div>
    </div>
  </section>

  <section class="py-20 lg:py-28">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid lg:grid-cols-5 gap-12 lg:gap-20">
        <div class="lg:col-span-3 reveal">
          <div class="space-y-6 text-earth leading-relaxed">
            <p class="text-lg text-charcoal">
              I am a nurse, licensed massage therapist, author, and public speaker. I have been practicing massage therapy since 2001, and I am a professional member of the AMTA, American Massage Therapy Association.
            </p>
            <p>
              I have been interviewed on the Chamber Focus program on Peters Township Cable TV discussing Breast Cancer and my Breast Health Awareness Program. The Washington Observer Reporter has written articles about my work with Fibromyalgia-Pain and my Breast Health Program.
            </p>
            <p>
              I have written numerous articles published in the Southwestern Guide to Good Health Magazine. I have also been involved in many public speaking events presenting a variety of topics and I am an advocate for women's health.
            </p>
            <p>
              My business, Ahhh A Massage, has been the recipient of the <strong class="text-charcoal">Readers' Choice Award for Massage Therapy</strong>.
            </p>
          </div>

          <div class="mt-10 p-6 bg-sage-pale rounded-2xl reveal">
            <h2 class="font-display text-xl font-medium text-charcoal mb-3">Wellness Coaching</h2>
            <p class="text-earth leading-relaxed text-sm">
              Using both professions as a nurse and massage therapist, I want to get to the root of your problem. In order to do that, it is important for you to be honest and thorough when filling out the intake form. I will ask you additional questions during your first visit in order to understand the big picture.
            </p>
          </div>
        </div>

        <div class="lg:col-span-2 reveal">
          <div class="sticky top-28 space-y-6">
            <img src="/images/margie.jpg" alt="Margie Webb, R.N., BCTMB" class="w-full rounded-2xl shadow-lg" loading="lazy" />
            <div class="bg-white rounded-2xl p-6 border border-sage-pale">
              <h3 class="font-display text-lg font-medium text-charcoal mb-1">Margie Webb</h3>
              <p class="text-sage font-medium text-sm">R.N., BCTMB</p>
              <p class="text-earth text-sm mt-1">Licensed Massage Therapist</p>
              <p class="text-earth/60 text-xs mt-1">PA License #MSG001784</p>
              <div class="flex items-center gap-4 mt-4">
                <img src="/images/amta-logo.png" alt="AMTA" class="h-8 opacity-70" loading="lazy" />
                <img src="/images/bctmb-logo.png" alt="BCTMB" class="h-8 opacity-70" loading="lazy" />
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-sage-dark py-16 text-center">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl font-light text-white mb-4">Schedule Your Visit</h2>
      <p class="text-white/60 mb-8">Call for a free consultation.</p>
      <a href="tel:4128778569" class="btn bg-white text-sage-dark border-2 border-white hover:bg-transparent hover:text-white">Call Margie — (412) 877-8569</a>
    </div>
  </section>
</Layout>
