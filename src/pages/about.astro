---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import practitionerImg from '../../public/images/interview-2b3-480w.jpg';
import bctmbImg from '../../public/images/bctmb-logo--board-certified-224w.jpg';
import amtaImg from '../../public/images/amta-0c468e1c-317w.jpg';
import waterImg from '../../public/images/b3-1920w.jpg';
import gardenImg from '../../public/images/ahh-a-massage-outside-4-1920w.jpg';
import seatingImg from '../../public/images/ahh-a-massage-outside-3-1920w.jpg';
---

<Layout
  title="Meet Margie Webb, R.N., BCTMB"
  description="Margie Webb is a registered nurse, board-certified massage therapist, author, and public speaker practicing in McMurray, PA since 2001. Specializing in therapeutic and medical massage."
>
  <!-- About Hero -->
  <section class="bg-background pt-16 md:pt-24 pb-10 md:pb-14">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <div class="grid grid-cols-1 md:grid-cols-[40fr_60fr] gap-10 md:gap-14 items-start">
        <Image
          src={practitionerImg}
          alt="Margie Webb performing shoulder massage at Ahhh A Massage, McMurray PA"
          class="rounded-xl border-2 border-accent/30 w-full object-cover"
          widths={[300, 480]}
          sizes="(max-width: 768px) 100vw, 40vw"
          loading="eager"
          fetchpriority="high"
        />
        <div>
          <h1 class="mb-2">Your Massage Therapist</h1>
          <h2 class="text-primary mb-6">Margie Webb, R.N., BCTMB</h2>
          <ul class="space-y-2 text-muted-foreground text-sm">
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
              Licensed Massage Therapist, PA License #MSG001784
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
              Registered Nurse (R.N.)
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
              Board Certified in Therapeutic Massage and Bodywork (BCTMB)
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
              Professional Member, AMTA
            </li>
            <li class="flex items-start gap-2">
              <span class="mt-1.5 w-1.5 h-1.5 bg-accent rounded-full shrink-0"></span>
              Practicing since 2001
            </li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- About Story -->
  <section class="bg-white py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[680px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <h2 class="mb-8">Nurse, Therapist, Advocate</h2>
      <div class="space-y-5 text-muted-foreground leading-relaxed">
        <p>
          Margie is a nurse, licensed massage therapist, author, and public speaker. She has been practicing massage therapy since 2001 and is a professional member of the American Massage Therapy Association.
        </p>
        <p>
          Using both professions, nursing and massage therapy, Margie gets to the root of your problem. After reviewing your confidential intake form, she will ask additional questions during your first visit to understand the full picture. During the massage, she uses her hands to palpate the texture of your muscles, which reveals where stress and restriction are being held.
        </p>
        <p>
          Margie has been interviewed on the Chamber Focus program on Peters Township Cable TV discussing breast cancer and her Breast Health Awareness Program. The Washington Observer Reporter has written articles about her work with fibromyalgia and her breast health program.
        </p>
        <p>
          She has written numerous articles published in the Southwestern Guide to Good Health Magazine, presented at public speaking events on a variety of health topics, and is an advocate for women's health.
        </p>
        <p>
          Her business, Ahhh A Massage, has been the recipient of the Readers' Choice Award for Massage Therapy.
        </p>
      </div>
    </div>
  </section>

  <!-- Credentials Bar -->
  <section class="bg-muted py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-4 gap-6">
        <div class="border-t-2 border-accent p-5">
          <Image
            src={bctmbImg}
            alt="BCTMB Board Certified in Therapeutic Massage and Bodywork"
            class="h-12 w-auto object-contain mb-3"
            width={90}
            height={84}
            loading="lazy"
          />
          <h3 class="font-display text-base mb-1">BCTMB</h3>
          <p class="text-muted-foreground text-sm">Board Certified in Therapeutic Massage and Bodywork</p>
        </div>
        <div class="border-t-2 border-accent p-5">
          <Image
            src={amtaImg}
            alt="AMTA American Massage Therapy Association membership badge"
            class="h-8 w-auto object-contain mb-3"
            width={160}
            height={44}
            loading="lazy"
          />
          <h3 class="font-display text-base mb-1">AMTA Member</h3>
          <p class="text-muted-foreground text-sm">American Massage Therapy Association, Professional Member</p>
        </div>
        <div class="border-t-2 border-accent p-5">
          <h3 class="font-display text-base mb-1 mt-[60px] sm:mt-0">PA License #MSG001784</h3>
          <p class="text-muted-foreground text-sm">Licensed by the Commonwealth of Pennsylvania</p>
        </div>
        <div class="border-t-2 border-accent p-5">
          <h3 class="font-display text-base mb-1 mt-[60px] sm:mt-0">R.N.</h3>
          <p class="text-muted-foreground text-sm">Registered Nurse. Clinical expertise informing every session.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Wellness Coaching -->
  <section class="bg-white py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <div class="grid grid-cols-1 md:grid-cols-[60fr_40fr] gap-10 md:gap-14 items-center">
        <div>
          <h2 class="mb-5">Wellness Coaching</h2>
          <p class="text-muted-foreground leading-relaxed mb-6">
            A session with Margie doesn't end when you leave the table. She provides guidance on posture, ergonomics, stretching, hydration, and sleep positioning. The between-session habits that extend and amplify the work done during your massage.
          </p>
          <ul class="space-y-2.5 text-muted-foreground text-sm">
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 bg-accent rounded-full shrink-0"></span>
              Desk and chair ergonomics for office workers
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 bg-accent rounded-full shrink-0"></span>
              Stretching exercises for your specific condition
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 bg-accent rounded-full shrink-0"></span>
              Hydration and nutrition basics
            </li>
            <li class="flex items-start gap-3">
              <span class="mt-1.5 w-2 h-2 bg-accent rounded-full shrink-0"></span>
              Sleep position adjustments for neck and back relief
            </li>
          </ul>
        </div>
        <Image
          src={waterImg}
          alt="Glass of water, hydration is part of the recovery process after massage therapy"
          class="rounded-xl w-full object-cover aspect-[4/3]"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, 40vw"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- The Studio -->
  <section class="bg-muted py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mb-8">
        <Image
          src={gardenImg}
          alt="Serenity garden at Ahhh A Massage, McMurray PA"
          class="rounded-lg w-full object-cover aspect-[4/3]"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <Image
          src={seatingImg}
          alt="Outdoor seating area at Ahhh A Massage studio"
          class="rounded-lg w-full object-cover aspect-[4/3]"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
      </div>
      <h2 class="mb-4">The Studio</h2>
      <p class="text-muted-foreground leading-relaxed max-w-[640px]">
        The setting at 310 East McMurray Road was chosen for its serenity gardens and fish pond, designed as part of the relaxation experience before your session begins. Inside, low lights and calming music fill the room as you settle onto a heated table wrapped in soft flannel sheets.
      </p>
      <p class="mt-3 text-sm text-foreground font-medium">310 East McMurray Rd, McMurray, PA 15317</p>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-primary py-12 md:py-14">
    <div class="max-w-[800px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)] text-center">
      <h2 class="text-primary-foreground mb-4">Ready to Get Started?</h2>
      <a href="tel:4128778569" class="font-display text-2xl md:text-3xl font-bold text-primary-foreground block mb-6">(412) 877-8569</a>
      <a href="/contact" class="inline-block bg-primary-foreground text-primary px-8 py-3 rounded-full font-medium hover:opacity-90">
        Book a Session
      </a>
    </div>
  </section>
</Layout>
