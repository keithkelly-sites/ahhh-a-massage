---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';

import tableMassageImg from '../../public/images/slide8-e8fe8469-5d581ed7-eea9a257-1920w.jpg';
import chairMassageImg from '../../public/images/chair-massage-400w.jpg';
import fibroImg from '../../public/images/fibromyalgia-480w.jpg';
import massageImg from '../../public/images/b6-1920w.jpg';
---

<Layout
  title="Massage Services"
  description="Table massage, chair massage, relaxation massage, and medical/orthopedic massage in McMurray, PA. Specialties include fibromyalgia, arthritis, cancer treatment support, and post-surgical recovery."
>
  <!-- Services Hero -->
  <section class="bg-background pt-16 md:pt-24 pb-10 md:pb-14">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <h1 class="mb-6">Massage Services</h1>
      <p class="text-muted-foreground text-lg leading-relaxed max-w-[640px]">
        Every session begins with a confidential intake form and a conversation. After reviewing your history, Margie designs the massage around your individual needs, not a menu item.
      </p>
    </div>
  </section>

  <!-- Session Types -->
  <section class="bg-white py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)] space-y-16 md:space-y-20">

      <!-- Table Massage -->
      <div id="table-massage" class="scroll-mt-24">
        <div class="grid grid-cols-1 md:grid-cols-[1fr_40%] gap-8 md:gap-12 items-start">
          <div>
            <h2 class="mb-4">Table Massage</h2>
            <p class="text-muted-foreground leading-relaxed mb-4">
              A full-body session on a heated table, draped in soft flannel. On cooler days you sink into the warmth as calming music lets your mind drift. The pressure of each stroke adjusts throughout for your comfort.
            </p>
            <p class="text-sm text-muted-foreground">60 minutes | 90 minutes | Cash only</p>
          </div>
          <Image
            src={tableMassageImg}
            alt="Massage table at Ahhh A Massage studio, McMurray PA"
            class="rounded-lg w-full object-cover aspect-[4/3]"
            widths={[400, 600]}
            sizes="(max-width: 768px) 100vw, 40vw"
            loading="lazy"
          />
        </div>
      </div>

      <hr class="border-border" />

      <!-- Chair Massage -->
      <div id="chair-massage" class="scroll-mt-24">
        <div class="grid grid-cols-1 md:grid-cols-[40%_1fr] gap-8 md:gap-12 items-start">
          <Image
            src={chairMassageImg}
            alt="Chair massage at Ahhh A Massage, McMurray PA"
            class="rounded-lg w-full object-cover aspect-[4/3] order-last md:order-first"
            widths={[300, 400]}
            sizes="(max-width: 768px) 100vw, 40vw"
            loading="lazy"
          />
          <div>
            <h2 class="mb-4">Chair Massage</h2>
            <p class="text-muted-foreground leading-relaxed mb-4">
              A targeted treatment that fits into a lunch break. No clothing needs to be removed. You leave feeling more alert and focused, ready to return to your day. Ideal for office workers and people managing repetitive strain.
            </p>
            <p class="text-sm text-muted-foreground">Duration varies | Cash only</p>
          </div>
        </div>
      </div>

      <hr class="border-border" />

      <!-- Relaxation Massage -->
      <div id="relaxation-massage" class="scroll-mt-24">
        <h2 class="mb-4">Relaxation Massage</h2>
        <p class="text-muted-foreground leading-relaxed max-w-[640px] mb-4">
          Releases tension throughout the body and lowers stress levels. Improves circulation, promotes calm, and provides the therapeutic touch that daily life rarely offers.
        </p>
        <p class="text-sm text-muted-foreground">Available as 60 or 90 min table session</p>
      </div>

      <hr class="border-border" />

      <!-- Medical Massage -->
      <div id="medical-massage" class="scroll-mt-24">
        <h2 class="mb-4">Medical / Orthopedic Massage</h2>
        <p class="text-muted-foreground leading-relaxed max-w-[640px] mb-4">
          Goes beyond stress relief. Manages pain, reduces inflammation, relieves nerve compression, and can improve digestion and mobility. Margie's nursing background allows her to work directly from your medical history.
        </p>
        <p class="text-sm text-muted-foreground">Duration tailored to condition | Cash only</p>
      </div>
    </div>
  </section>

  <!-- Therapeutic Specialties -->
  <section class="bg-muted py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <h2 class="mb-3">Therapeutic Specialties</h2>
      <p class="text-muted-foreground leading-relaxed max-w-[640px] mb-10">
        These aren't upsells. They're the conditions Margie has spent 25 years treating. If you've been told massage won't help, talk to her first.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Chronic Stress</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Chronic stress, whether physical, emotional, or mental, causes muscles to shorten and retain toxins, perpetuating the pain cycle. Margie assesses the physical changes and helps muscles release and re-adjust.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Muscle Spasms</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Spasms from gardening, shoveling, sports, or daily activity. Targeted release work addresses the muscle directly, not just the symptom.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Arthritis Pain</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Decreases muscle tightness and joint pain. Increases flexibility. Regular sessions have helped clients avoid escalation to more invasive treatments.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Fibromyalgia</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Desensitizes tender points and relaxes tight, stressed muscles. Margie hosted public education sessions on fibromyalgia and has been featured in regional press for this work.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Repetitive Movement Injuries</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Releases trigger points from texting, data entry, and poor head/neck/shoulder posture. Investigates and stretches the muscles driving the pain.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Headaches, Carpal Tunnel & TMJ</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Addresses the muscular roots of recurring headaches, carpal tunnel symptoms, and jaw tension. Often resolves where other treatments have not.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Cancer Treatment Support</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Safe, adapted massage during chemotherapy and radiation. Decreases stress, reduces nausea, and provides therapeutic touch during a physically demanding period.</p>
        </div>
        <div class="border-t-2 border-accent bg-background p-6 rounded-lg">
          <h3 class="font-display text-lg mb-2">Post-Surgical Recovery</h3>
          <p class="text-muted-foreground text-sm leading-relaxed">Restores flexibility to muscles disturbed by surgery. Specialized experience with mastectomy, breast surgery, neck and back surgery. Works alongside physician recommendations.</p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-3 mt-8">
        <Image
          src={fibroImg}
          alt="Massage therapy for fibromyalgia at Ahhh A Massage, McMurray PA"
          class="rounded-lg w-full object-cover aspect-[16/9]"
          widths={[400, 600]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
        <Image
          src={massageImg}
          alt="Woman receiving therapeutic massage at Ahhh A Massage"
          class="rounded-lg w-full object-cover aspect-[16/9]"
          widths={[400, 800]}
          sizes="(max-width: 768px) 100vw, 50vw"
          loading="lazy"
        />
      </div>
    </div>
  </section>

  <!-- Booking & Payment -->
  <section class="bg-white py-[var(--section-padding-y-mobile)] md:py-[var(--section-padding-y)]">
    <div class="max-w-[1200px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)]">
      <h2 class="mb-10">Booking & Payment</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-14">
        <div>
          <p class="font-display text-2xl font-bold mb-2">
            <a href="tel:4128778569" class="text-primary hover:opacity-85">(412) 877-8569</a>
          </p>
          <p class="text-sm text-muted-foreground mb-6">Call to schedule your appointment</p>

          <table class="w-full text-sm mb-6">
            <tbody>
              <tr class="border-b border-border">
                <td class="py-2.5 text-foreground font-medium">Mon &ndash; Thu</td>
                <td class="py-2.5 text-muted-foreground text-right">9:00 am &ndash; 8:00 pm</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-2.5 text-foreground font-medium">Fri</td>
                <td class="py-2.5 text-muted-foreground text-right">9:00 am &ndash; 5:00 pm</td>
              </tr>
              <tr class="border-b border-border">
                <td class="py-2.5 text-foreground font-medium">Sat</td>
                <td class="py-2.5 text-muted-foreground text-right">By appointment</td>
              </tr>
              <tr>
                <td class="py-2.5 text-foreground font-medium">Sun</td>
                <td class="py-2.5 text-muted-foreground text-right">Closed</td>
              </tr>
            </tbody>
          </table>

          <p class="text-sm font-medium text-foreground">Payment: Cash only</p>
        </div>

        <div>
          <h3 class="font-display text-lg mb-3">New Client Intake Form</h3>
          <p class="text-muted-foreground text-sm leading-relaxed mb-4">
            New clients: please download and complete the patient intake form before your first visit. Honesty and thoroughness on the form helps Margie prepare the most effective session.
          </p>
          <a
            href="https://irp-cdn.multiscreensite.com/6097f8c0/files/uploaded/Intake%20Form%20-%20New.pdf"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 bg-muted text-foreground px-5 py-2.5 rounded-lg text-sm font-medium hover:bg-border"
          >
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
            Download Intake Form (PDF)
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Band -->
  <section class="bg-primary py-12 md:py-14">
    <div class="max-w-[800px] mx-auto px-[var(--padding-x-mobile)] md:px-[var(--padding-x)] text-center">
      <h2 class="text-primary-foreground mb-3">Questions Before You Book?</h2>
      <p class="text-primary-foreground/80 mb-6">Call for a free consultation.</p>
      <a href="tel:4128778569" class="font-display text-2xl md:text-3xl font-bold text-primary-foreground block mb-6">(412) 877-8569</a>
      <a href="/contact" class="inline-block bg-primary-foreground text-primary px-8 py-3 rounded-full font-medium hover:opacity-90">
        Contact Margie
      </a>
    </div>
  </section>
</Layout>
